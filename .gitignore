# Python
.venv/
**/__pycache__/
*.pyc

# Secrets
**/.env
**/.env.local

# Ingested data (regenerable)
backend/chroma_db/

# Source PDFs — too large for GitHub (50MB per-file cap).
# Place them in backend/pdf/ locally and run ingest_folder.py to populate Chroma.
backend/pdf/

# Node / Vite
node_modules/
dist/
dist-ssr/
.vite/

# Capacitor native projects — regenerate with `npm run cap:add:android` /
# `cap:add:ios`. Kept out of git to stay lightweight; config lives in
# frontend/capacitor.config.ts.
frontend/android/
frontend/ios/

# Dev local items
.notes/
*.local.*

# npm home used by deploy/update.sh (keeps npm's cache out of the repo root)
/.npm-home/

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/
