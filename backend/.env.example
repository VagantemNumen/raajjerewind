# Gemini API key (required).
GEMINI_API_KEY=

# Admin password used to gate /upload and /admin/* endpoints.
# Pick something long and random — there is no rate limiting on /admin/login.
ADMIN_PASSWORD=

# Comma-separated frontend origins allowed by CORS.
# Dev defaults to the Vite dev server; override in production with your real domain.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
