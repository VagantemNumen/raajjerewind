# URL of the FastAPI backend used by the dev proxy (/api/*).
# In production, the frontend is served from the same origin so this is unused.
VITE_BACKEND_URL=http://127.0.0.1:8000

# Extra hosts to allow through Vite's dev/preview host check.
# Comma-separated. Use a leading dot for wildcard subdomain matches.
# Common tunnel providers (.ngrok-free.app / .trycloudflare.com) are already
# allowed by default — only add to this list for custom domains or other tunnels.
# VITE_ALLOWED_HOSTS=.example.com,my-tunnel.lhr.life
